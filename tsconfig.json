{
  "extends": ["@tsconfig/strictest/tsconfig.json"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts", "src/routeTree.gen.ts"],
  "exclude": ["node_modules", ".output", ".nitro"]
}
