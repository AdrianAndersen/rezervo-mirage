{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun build"
  },
  "deploy": {
    "startCommand": "bun start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS",
    "cronSchedule": null,
    "multiRegionConfig": {
      "europe-west4-drams3a": { "numReplicas": 1 }
    }
  }
}
